# Copy to .env.local and fill in.

# REQUIRED — your own OpenRouter key (openrouter.ai/settings/keys). Pay-per-use;
# a typical answer costs well under a cent on the default model.
OPENROUTER_API_KEY=

# Optional — the OpenRouter model to answer with.
GT_MODEL=google/gemini-3.5-flash

# Optional — Voyage AI key (free tier at dashboard.voyageai.com). When set,
# retrieval upgrades from full-text (FTS5) to semantic vector search.
VOYAGE_API_KEY=
